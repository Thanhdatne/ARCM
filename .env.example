# ArcSignal / official Arc prediction markets sample env template.
# Copy this file to .env.local and replace placeholders with local values.
# Never commit real private keys or production secrets.

# Deployer wallet private key for contract deployment and server-side
# dynamic market creation. Placeholder only.
PRIVATE_KEY=your_private_key_here

# Arc Testnet RPC URL used by both Hardhat and the frontend.
# The variable name is inherited from the official sample app.
NEXT_PUBLIC_ALCHEMY_RPC_URL=https://rpc.testnet.arc.network

# Arc Testnet reference values:
# Chain ID: 5042002
# Explorer: https://testnet.arcscan.app
# Native gas token display: USDC
# Current sample market collateral: ARCT test collateral

# Public Arc/Circle capability configuration. These values are safe to expose,
# but the feature flags must stay false until the corresponding implementation
# has been verified end to end.
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_ARC_EURC_ADDRESS=
NEXT_PUBLIC_ARC_GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
NEXT_PUBLIC_ARC_CCTP_DOMAIN=26

# Do not enable USDC/EURC collateral until contract compatibility and
# token-decimal handling are implemented and verified.
NEXT_PUBLIC_ENABLE_USDC_COLLATERAL=false
NEXT_PUBLIC_ENABLE_EURC_COLLATERAL=false

# These flags describe UI capability only. They do not create fake deposits or
# make CCTP/Gateway operational without a real wallet-signed implementation.
NEXT_PUBLIC_ENABLE_CCTP_DEPOSIT=false
NEXT_PUBLIC_ENABLE_GATEWAY_DEPOSIT=false

# Never place private keys, service-role keys, admin keys, Circle API keys, or
# other secrets in a NEXT_PUBLIC variable.

# Admin/local UI gate for market creation. Keep false for public demos when
# /api/create-market uses a server-side PRIVATE_KEY.
NEXT_PUBLIC_ENABLE_ADMIN_MARKET_CREATE=false

# Optional server-side football data provider key for future World Cup live
# score display. Never expose this as NEXT_PUBLIC_*.
FOOTBALL_API_KEY=

# Circle modular wallets (required for passkey wallet support)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=your_circle_client_key_here
NEXT_PUBLIC_CIRCLE_CLIENT_URL=your_circle_client_url_here

# Contract addresses auto-written by scripts/deploy.ts after deployment.
# Keep these as placeholders in committed examples.
# NEXT_PUBLIC_MARKET_ADDRESS=0x...
# NEXT_PUBLIC_AMM_ADDRESS=0x...
# NEXT_PUBLIC_ARCT_ADDRESS=0x...
# NEXT_PUBLIC_OO_V2_ADDRESS=0x...
# NEXT_PUBLIC_FINDER_ADDRESS=0x...
# NEXT_PUBLIC_TIMER_ADDRESS=0x...
# NEXT_PUBLIC_MOCK_ORACLE_ADDRESS=0x...
